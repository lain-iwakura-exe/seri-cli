VERSION="4.6.0"
QUALITY="${QUALITY:-best}"
ARABIC_PRIORITY="${ARABIC_PRIORITY:-yes}"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/seri-cli/history"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/seri-cli/config"
TMDB_KEY="${TMDB_KEY:-037e92c800c648af4e68b0661944c690}"
TMDB_BASE="https://api.themoviedb.org/3"

c_red='\033[0;31m'; c_grn='\033[0;32m'; c_ylw='\033[1;33m'
c_blu='\033[0;34m'; c_cyn='\033[0;36m'; c_bld='\033[1m'
c_dim='\033[2m';    c_rst='\033[0m'

msg_info() { printf "${c_blu}[~]${c_rst} %s\n" "$*"; }
msg_ok()   { printf "${c_grn}[v]${c_rst} %s\n" "$*"; }
msg_warn() { printf "${c_ylw}[!]${c_rst} %s\n" "$*"; }
msg_err()  { printf "${c_red}[x]${c_rst} %s\n" "$*"; }
msg_play() { printf "${c_grn}[>]${c_rst} ${c_bld}%s${c_rst}\n" "$*"; }

banner() {
    printf "${c_cyn}${c_bld}"
    cat << 'EOF'
  ___  ___ _ __ (_)      ___| (_)
 / __|/ _ \ '__|| |____ / __| | |
 \__ \  __/ |   | |____| (__| | |
 |___/\___|_|   |_|     \___|_|_|
EOF
    printf "${c_rst}${c_dim}  stream series & films on Linux  v${VERSION}${c_rst}\n\n"
}

dep_check() {
    local missing=()
    for cmd in curl mpv fzf jq python3; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        msg_err "Missing dependencies: ${missing[*]}"
        command -v pacman &>/dev/null && echo "  sudo pacman -S ${missing[*]}"
        command -v apt    &>/dev/null && echo "  sudo apt install ${missing[*]}"
        command -v dnf    &>/dev/null && echo "  sudo dnf install ${missing[*]}"
        exit 1
    fi
    if ! command -v peerflix &>/dev/null; then
        msg_err "Missing peerflix. Install it:"
        echo "  sudo npm install -g peerflix"
        exit 1
    fi
}

init_dirs() {
    mkdir -p "$(dirname "$HISTORY_FILE")" "$(dirname "$CONFIG_FILE")"
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
}

urlencode() {
    python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

history_add() { echo "$1" >> "$HISTORY_FILE"; }
history_show() {
    [[ ! -s "$HISTORY_FILE" ]] && { msg_warn "No history yet."; return; }
    printf "${c_cyn}${c_bld}-- Watch History ---------------------${c_rst}\n"
    tac "$HISTORY_FILE" | head -30 | nl -w2 -s'. '
}

# ── TMDB ──────────────────────────────────────────────────────
tmdb_search() {
    curl -sf "${TMDB_BASE}/search/multi?api_key=${TMDB_KEY}&query=$(urlencode "$1")"
}

tmdb_details() {
    curl -sf "${TMDB_BASE}/${2}/${1}?api_key=${TMDB_KEY}"
}

tmdb_season() {
    curl -sf "${TMDB_BASE}/tv/${1}/season/${2}?api_key=${TMDB_KEY}"
}

tmdb_to_imdb() {
    local type="$1" tmdb_id="$2"
    curl -sf "${TMDB_BASE}/${type}/${tmdb_id}/external_ids?api_key=${TMDB_KEY}" \
        | jq -r '.imdb_id // empty' 2>/dev/null
}

parse_results() {
    echo "$1" | jq -r '
        .results[] |
        select(.media_type != "person") |
        select(.title != null or .name != null) |
        [ (.media_type // "movie"), (.id|tostring),
          (.title // .name),
          ((.release_date // .first_air_date // "")[0:4]) ] | join("\t")
    ' 2>/dev/null
}

# ── Torrentio ─────────────────────────────────────────────────
get_streams() {
    local type="$1" imdb_id="$2" season="$3" ep="$4"
    local stype sid

    if [[ "$type" == "movie" ]]; then
        stype="movie"
        sid="${imdb_id}"
    else
        stype="series"
        sid="${imdb_id}:${season}:${ep}"
    fi

    curl -sf --max-time 15 \
        "https://torrentio.strem.fun/stream/${stype}/${sid}.json" 2>/dev/null
}

# Returns ordered list of hash:fileidx
# Priority: Arabic-subbed 1080p > Arabic-subbed 720p > Arabic-subbed any >
#           1080p > 720p > anything else
get_all_hashes() {
    local json="$1"
    local result=""
    local arabic_pattern="ARABIC|Arabic|مترجم|AR Sub|Arab Sub|ARA |\\.AR\\.|\\[AR\\]"

    if [[ "$ARABIC_PRIORITY" == "yes" ]]; then
    # Arabic + 1080p
    result=$(echo "$json" | jq -r --arg pat "$arabic_pattern" '
        .streams[] | select(.infoHash != null) |
        select(.title != null and (.title | test($pat; "i"))) |
        select(.title | test("1080")) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)

    # Arabic + 720p
    result+=$'\n'$(echo "$json" | jq -r --arg pat "$arabic_pattern" '
        .streams[] | select(.infoHash != null) |
        select(.title != null and (.title | test($pat; "i"))) |
        select(.title | test("720")) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)

    # Arabic, any quality
    result+=$'\n'$(echo "$json" | jq -r --arg pat "$arabic_pattern" '
        .streams[] | select(.infoHash != null) |
        select(.title != null and (.title | test($pat; "i"))) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)
    fi

    # Non-Arabic 1080p
    result+=$'\n'$(echo "$json" | jq -r '
        .streams[] | select(.infoHash != null) |
        select(.title != null and (.title | test("1080"))) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)

    # Non-Arabic 720p
    result+=$'\n'$(echo "$json" | jq -r '
        .streams[] | select(.infoHash != null) |
        select(.title != null and (.title | test("720"))) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)

    # Everything else
    result+=$'\n'$(echo "$json" | jq -r '
        .streams[] | select(.infoHash != null) |
        [.infoHash, (.fileIdx // 0 | tostring)] | join(":")
    ' 2>/dev/null)

    echo "$result" | grep -v '^$' | awk '!seen[$0]++' | head -20
}

# ── Build magnet ──────────────────────────────────────────────
build_magnet() {
    local hash="$1"
    local magnet="magnet:?xt=urn:btih:${hash}"
    magnet+="&tr=udp%3A%2F%2Fopen.demonii.com%3A1337%2Fannounce"
    magnet+="&tr=udp%3A%2F%2Ftracker.openbittorrent.com%3A80%2Fannounce"
    magnet+="&tr=udp%3A%2F%2Ftracker.opentrackr.org%3A1337%2Fannounce"
    magnet+="&tr=udp%3A%2F%2Fp4p.arenabg.com%3A1337%2Fannounce"
    magnet+="&tr=udp%3A%2F%2Ftracker.leechers-paradise.org%3A6969%2Fannounce"
    echo "$magnet"
}

# ── Play ──────────────────────────────────────────────────────
play_torrent() {
    local hash="$1" file_idx="$2" title="$3"
    local magnet
    magnet=$(build_magnet "$hash")

    msg_play "Playing: ${title}"
    msg_info "Hash: ${hash:0:12}... FileIdx: ${file_idx}"

    if ! command -v peerflix &>/dev/null; then
        msg_err "peerflix not found. Install: sudo npm install -g peerflix"
        return 1
    fi

    # Kill any existing peerflix
    pkill -f peerflix 2>/dev/null
    sleep 1

    # Start peerflix HTTP server in background
    msg_info "Starting peerflix HTTP server..."
    if [[ "$file_idx" == "0" ]]; then
        peerflix "$magnet" --port 8888 &>/tmp/peerflix.log &
    else
        peerflix "$magnet" --port 8888 --index "$file_idx" &>/tmp/peerflix.log &
    fi
    local peerflix_pid=$!

    # Wait for server AND check for peers — fail fast on dead torrents
    msg_info "Checking for peers..."
    local tries=0
    local server_up=0
    local has_peers=0
    local max_wait=15   # only wait 15s before giving up on a dead stream

    while [[ $tries -lt $max_wait ]]; do
        sleep 1
        tries=$((tries + 1))

        if curl -sf --max-time 1 "http://localhost:8888" &>/dev/null; then
            server_up=1
        fi

        local peer_line
        peer_line=$(grep "peers" /tmp/peerflix.log 2>/dev/null | tail -1)

        # Dead torrent detection — 0/0 peers after 4 seconds = skip immediately
        if [[ $tries -ge 4 ]] && echo "$peer_line" | grep -q "0/0 peers"; then
            msg_warn "Dead torrent (0 peers), skipping..."
            kill "$peerflix_pid" 2>/dev/null
            pkill -f peerflix 2>/dev/null
            return 1
        fi

        local peer_count
        peer_count=$(echo "$peer_line" | grep -oP "from \K[0-9]+" 2>/dev/null)
        if [[ -n "$peer_count" ]] && [[ "$peer_count" -gt 0 ]]; then
            has_peers=1
        fi

        if [[ $server_up -eq 1 ]] && [[ $has_peers -eq 1 ]]; then
            msg_ok "Found peers, stream is ready!"
            break
        fi
    done

    if [[ $server_up -eq 0 ]] || [[ $has_peers -eq 0 ]]; then
        msg_warn "No peers found within ${max_wait}s, skipping this stream..."
        kill "$peerflix_pid" 2>/dev/null
        pkill -f peerflix 2>/dev/null
        return 1
    fi

    # Launch MPV
    msg_info "Opening MPV..."
    mpv         --title="${title}"         --force-window=yes         --keep-open=yes         --osd-level=1         --save-position-on-quit         "http://localhost:8888"
    local exit_code=$?

    kill "$peerflix_pid" 2>/dev/null
    pkill -f peerflix 2>/dev/null
    return $exit_code
}

play_direct() {
    local url="$1" title="$2"
    msg_play "Playing: ${title}"
    mpv \
        --title="${title}" \
        --force-window=yes \
        --keep-open=yes \
        --osd-level=1 \
        --save-position-on-quit \
        --user-agent="Mozilla/5.0" \
        "$url"
}

# Try streams one by one until one works
try_all_streams() {
    local streams_json="$1" title="$2"

    # Check for direct URL first
    local direct_url
    direct_url=$(echo "$streams_json" | jq -r \
        '.streams[] | select(.url != null) | .url' 2>/dev/null | head -1)
    if [[ -n "$direct_url" ]]; then
        play_direct "$direct_url" "$title"
        return $?
    fi

    # Try torrent streams
    local all_hashes
    all_hashes=$(get_all_hashes "$streams_json")

    if [[ -z "$all_hashes" ]]; then
        msg_err "No streams found."
        return 1
    fi

    local total
    total=$(echo "$all_hashes" | wc -l)
    msg_info "Found ${total} streams, trying best one..."

    local count=0
    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        count=$((count + 1))
        local hash file_idx
        hash=$(echo "$entry" | cut -d: -f1)
        file_idx=$(echo "$entry" | cut -d: -f2)

        msg_info "Stream ${count}/${total}"
        play_torrent "$hash" "${file_idx:-0}" "$title"
        local exit_code=$?

        if [[ $exit_code -eq 0 ]]; then
            return 0
        fi

        msg_warn "Stream ${count} failed, trying next..."
    done <<< "$all_hashes"

    msg_err "All streams failed."
    return 1
}

# ── Pickers ───────────────────────────────────────────────────
pick_title() {
    local results="$1" query="$2"
    local fzf_input

    fzf_input=$(echo "$results" | while IFS=$'\t' read -r type id title year; do
        [[ -z "$id" ]] && continue
        local icon="[TV]"
        [[ "$type" == "movie" ]] && icon="[Movie]"
        printf "%s\t%s\t%s\t%s %s (%s)\n" "$type" "$id" "$title" "$icon" "$title" "$year"
    done)

    local selected
    selected=$(echo "$fzf_input" | awk -F'\t' '{print $4}' | fzf \
        --prompt="Select > " --height=40 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7" \
        --header="seri-cli -- ${query}")
    [[ -z "$selected" ]] && return 1

    echo "$fzf_input" | awk -F'\t' -v s="$selected" '$4==s{print;exit}'
}

pick_episode() {
    local show_id="$1" show_name="$2" total_seasons="$3"

    local season
    season=$(seq 1 "$total_seasons" | awk '{print "Season "$1}' | fzf \
        --prompt="Season > " --height=20 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa,prompt:#89b4fa,pointer:#f5c2e7" \
        --header="$show_name" | grep -oP '\d+')
    [[ -z "$season" ]] && return 1

    local ep_list
    ep_list=$(tmdb_season "$show_id" "$season" | jq -r \
        '.episodes[] | "\(.episode_number). \(.name) (\(.air_date // "TBA"))"' 2>/dev/null)
    [[ -z "$ep_list" ]] && { msg_err "No episodes found."; return 1; }

    local ep_line ep_num
    ep_line=$(echo "$ep_list" | fzf \
        --prompt="Episode > " --height=30 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#a6e3a1,prompt:#a6e3a1,pointer:#f5c2e7" \
        --header="${show_name} -- Season ${season}")
    [[ -z "$ep_line" ]] && return 1

    ep_num=$(echo "$ep_line" | grep -oP '^\d+')
    echo "${season}|${ep_num}"
}

what_next() {
    printf 'Replay\nNext episode\nDifferent episode\nQuit' | fzf \
        --prompt="What next > " --height=8 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8,prompt:#f38ba8,pointer:#f5c2e7"
}

select_quality() {
    printf 'best\n1080p\n720p\n480p\n360p' | fzf \
        --prompt="Quality > " --height=10 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7"
}

# ── Main ──────────────────────────────────────────────────────
search_and_play() {
    local query="$1"
    msg_info "Searching: ${query}"

    local json results
    json=$(tmdb_search "$query")

    if [[ -z "$json" ]] || echo "$json" | jq -e '.results | length == 0' &>/dev/null; then
        msg_err "No results found."
        return 1
    fi

    results=$(parse_results "$json")
    [[ -z "$results" ]] && { msg_err "No results."; return 1; }

    local row
    row=$(pick_title "$results" "$query")
    [[ $? -ne 0 || -z "$row" ]] && return 0

    local media_type media_id title
    media_type=$(echo "$row" | cut -f1)
    media_id=$(echo "$row"   | cut -f2)
    title=$(echo "$row"      | cut -f3)

    msg_info "Fetching IMDB ID..."
    local imdb_id
    imdb_id=$(tmdb_to_imdb "$media_type" "$media_id")
    if [[ -z "$imdb_id" ]]; then
        msg_err "Could not find IMDB ID for: ${title}"
        return 1
    fi
    msg_ok "IMDB ID: ${imdb_id}"

    local quality
    quality=$(select_quality)
    [[ -z "$quality" ]] && quality="best"

    if [[ "$media_type" == "movie" ]]; then
        msg_info "Fetching streams..."
        local streams
        streams=$(get_streams "movie" "$imdb_id" "" "")
        history_add "movie|${imdb_id}|${title}"
        try_all_streams "$streams" "$title"

    else
        local details total_seasons
        details=$(tmdb_details "$media_id" "tv")
        total_seasons=$(echo "$details" | jq -r '.number_of_seasons // 1')
        local season ep streams

        while true; do
            local sep
            sep=$(pick_episode "$media_id" "$title" "$total_seasons")
            [[ $? -ne 0 || -z "$sep" ]] && break

            season=$(echo "$sep" | cut -d'|' -f1)
            ep=$(echo "$sep"     | cut -d'|' -f2)

            msg_info "Fetching streams..."
            streams=$(get_streams "series" "$imdb_id" "$season" "$ep")
            history_add "tv|${imdb_id}|${title}|S${season}E${ep}"
            try_all_streams "$streams" "${title} S${season}E${ep}"

            local action
            action=$(what_next)
            case "$action" in
                "Replay")
                    try_all_streams "$streams" "${title} S${season}E${ep}" ;;
                "Next episode")
                    ep=$((ep + 1))
                    msg_info "Fetching next episode..."
                    streams=$(get_streams "series" "$imdb_id" "$season" "$ep")
                    try_all_streams "$streams" "${title} S${season}E${ep}" ;;
                "Different episode") continue ;;
                *) break ;;
            esac
        done
    fi
}

self_update() {
    msg_info "Updating seri-cli..."
    local path
    path=$(command -v seri-cli 2>/dev/null || echo "/usr/local/bin/seri-cli")
    if curl -fsSL \
        "https://raw.githubusercontent.com/lain-iwakura-exe/seri-cli/main/seri-cli" \
        -o /tmp/seri-cli.update; then
        chmod +x /tmp/seri-cli.update
        sudo mv /tmp/seri-cli.update "$path"
        msg_ok "Updated to latest version!"
    else
        msg_err "Update failed."
    fi
}

usage() {
    cat << EOF
${c_bld}seri-cli${c_rst} v${VERSION} -- Stream series & films on Linux

${c_bld}USAGE${c_rst}
  seri-cli [OPTIONS] [QUERY]

${c_bld}OPTIONS${c_rst}
  -H, --history     Watch history
  -u, --update      Update seri-cli
  -h, --help        Help
  -v, --version     Version

${c_bld}EXAMPLES${c_rst}
  seri-cli "Breaking Bad"
  seri-cli "Interstellar"
  seri-cli "The Dark Knight"
  seri-cli "Fight Club"

${c_bld}DEPS${c_rst}
  Required : curl mpv fzf jq python3 nodejs npm
  Streaming: torrentflix
EOF
}

main() {
    dep_check
    init_dirs
    [[ $# -eq 0 ]] && { banner; usage; exit 0; }

    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            -v|--version) echo "seri-cli $VERSION"; exit 0 ;;
            -H|--history) history_show; exit 0 ;;
            -u|--update)  self_update; exit 0 ;;
            -*)           msg_err "Unknown flag: $1"; exit 1 ;;
            *)            query="$*"; break ;;
        esac
    done

    banner

    if [[ -z "$query" ]]; then
        printf "${c_cyn}Search > ${c_rst}"
        read -r query
        [[ -z "$query" ]] && exit 0
    fi

    search_and_play "$query"
}

main "$@"
