# ============================================================

VERSION="4.0.0"
QUALITY="${QUALITY:-best}"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/seri-cli/history"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/seri-cli/config"
TMDB_KEY="${TMDB_KEY:-037e92c800c648af4e68b0661944c690}"
TMDB_BASE="https://api.themoviedb.org/3"
STREMIO_PORT="${STREMIO_PORT:-11470}"
STREMIO_BASE="http://localhost:${STREMIO_PORT}"

# No ANSI in functions — only printed directly
c_red='\033[0;31m'; c_grn='\033[0;32m'; c_ylw='\033[1;33m'
c_blu='\033[0;34m'; c_cyn='\033[0;36m'; c_bld='\033[1m'
c_dim='\033[2m';    c_rst='\033[0m'

msg_info()  { printf "${c_blu}[~]${c_rst} %s\n" "$*"; }
msg_ok()    { printf "${c_grn}[✓]${c_rst} %s\n" "$*"; }
msg_warn()  { printf "${c_ylw}[!]${c_rst} %s\n" "$*"; }
msg_err()   { printf "${c_red}[✗]${c_rst} %s\n" "$*"; }
msg_play()  { printf "${c_grn}[▶]${c_rst} ${c_bld}%s${c_rst}\n" "$*"; }

banner() {
    printf "${c_cyn}${c_bld}"
    cat << 'EOF'
  ___  ___ _ __ (_)      ___| (_)
 / __|/ _ \ '__|| |____ / __| | |
 \__ \  __/ |   | |____| (__| | |
 |___/\___|_|   |_|     \___|_|_|
EOF
    printf "${c_rst}${c_dim}  stream series & films on Linux  v${VERSION}${c_rst}\n\n"
}

# ── Deps ──────────────────────────────────────────────────────
dep_check() {
    local missing=()
    for cmd in curl mpv fzf jq python3; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        msg_err "Missing dependencies: ${missing[*]}"
        command -v pacman &>/dev/null && echo "  sudo pacman -S ${missing[*]}"
        command -v apt    &>/dev/null && echo "  sudo apt install ${missing[*]}"
        exit 1
    fi
}

# ── Init ──────────────────────────────────────────────────────
init_dirs() {
    mkdir -p "$(dirname "$HISTORY_FILE")" "$(dirname "$CONFIG_FILE")"
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
}

urlencode() {
    python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

history_add()  { echo "$1" >> "$HISTORY_FILE"; }
history_show() {
    [[ ! -s "$HISTORY_FILE" ]] && { msg_warn "No history yet."; return; }
    printf "${c_cyn}${c_bld}── Watch History ──────────────────────${c_rst}\n"
    tac "$HISTORY_FILE" | head -30 | nl -w2 -s'. '
}

# ── Stremio server management ─────────────────────────────────
stremio_running() {
    curl -sf --max-time 2 "${STREMIO_BASE}/health" &>/dev/null
}

stremio_start() {
    if stremio_running; then
        msg_ok "Stremio server already running on port ${STREMIO_PORT}"
        return 0
    fi

    msg_info "Starting Stremio server…"

    # Try stremio-server binary (from stremio package)
    if command -v stremio-server &>/dev/null; then
        stremio-server &>/tmp/stremio-server.log &
        disown
    # Try the node server that ships with Stremio
    elif [[ -f "$HOME/.local/share/stremio/server.js" ]]; then
        node "$HOME/.local/share/stremio/server.js" &>/tmp/stremio-server.log &
        disown
    elif [[ -f "/opt/stremio/server.js" ]]; then
        node /opt/stremio/server.js &>/tmp/stremio-server.log &
        disown
    else
        msg_err "Stremio server not found. Please install Stremio."
        echo ""
        echo "  Install Stremio:"
        echo "  → Download from: https://www.stremio.com/downloads"
        echo "  → Or AUR: paru -S stremio"
        echo "  → Or Debian: sudo apt install stremio  (if available)"
        echo ""
        echo "  After installing, run Stremio once to set it up,"
        echo "  then run seri-cli again."
        exit 1
    fi

    # Wait for server to start (up to 10 seconds)
    local i=0
    while ! stremio_running && [[ $i -lt 20 ]]; do
        sleep 0.5
        ((i++))
    done

    if stremio_running; then
        msg_ok "Stremio server started"
    else
        msg_err "Stremio server failed to start. Check /tmp/stremio-server.log"
        exit 1
    fi
}

# ── Stremio stream fetching ───────────────────────────────────
# Convert TMDB ID to IMDB ID (Stremio uses IMDB IDs)
tmdb_to_imdb() {
    local type="$1" tmdb_id="$2"
    local endpoint
    if [[ "$type" == "movie" ]]; then
        endpoint="${TMDB_BASE}/movie/${tmdb_id}/external_ids?api_key=${TMDB_KEY}"
    else
        endpoint="${TMDB_BASE}/tv/${tmdb_id}/external_ids?api_key=${TMDB_KEY}"
    fi
    curl -sf "$endpoint" 2>/dev/null | jq -r '.imdb_id // empty'
}

# Get streams from Stremio's local server
stremio_get_streams() {
    local type="$1" imdb_id="$2" season="$3" ep="$4"
    local stremio_type stremio_id

    if [[ "$type" == "movie" ]]; then
        stremio_type="movie"
        stremio_id="${imdb_id}"
    else
        stremio_type="series"
        stremio_id="${imdb_id}:${season}:${ep}"
    fi

    # Query the Stremio local server for streams
    local url="${STREMIO_BASE}/stream/${stremio_type}/${stremio_id}.json"
    curl -sf --max-time 15 "$url" 2>/dev/null
}

# Parse stream response and pick best URL
pick_stream_url() {
    local json="$1" quality="$2"

    # Try to get a direct URL stream first
    local url
    url=$(echo "$json" | jq -r '
        .streams[] |
        select(.url != null) |
        select(.url | test("\\.(m3u8|mp4|mkv)")) |
        .url
    ' 2>/dev/null | head -1)

    [[ -n "$url" ]] && echo "$url" && return 0

    # Try any URL
    url=$(echo "$json" | jq -r '
        .streams[] | select(.url != null) | .url
    ' 2>/dev/null | head -1)

    [[ -n "$url" ]] && echo "$url" && return 0

    # Try infoHash (torrent-based stream) — MPV can handle magnet via peerflix/webtorrent
    local hash
    hash=$(echo "$json" | jq -r '
        .streams[] | select(.infoHash != null) | .infoHash
    ' 2>/dev/null | head -1)

    if [[ -n "$hash" ]]; then
        local file_idx
        file_idx=$(echo "$json" | jq -r '
            .streams[] | select(.infoHash != null) | .fileIdx // 0
        ' 2>/dev/null | head -1)
        echo "torrent:${hash}:${file_idx:-0}"
        return 0
    fi

    return 1
}

# Handle torrent streams via peerflix or webtorrent-mpv-hook
play_torrent() {
    local hash="$1" file_idx="$2" title="$3"

    if command -v peerflix &>/dev/null; then
        msg_info "Streaming via peerflix (torrent)…"
        peerflix "magnet:?xt=urn:btih:${hash}" --mpv --index "$file_idx" -- \
            --title="${title}" --force-window=yes --keep-open=yes
    elif command -v webtorrent &>/dev/null; then
        msg_info "Streaming via webtorrent (torrent)…"
        webtorrent "magnet:?xt=urn:btih:${hash}" --mpv
    else
        msg_warn "Torrent stream found but no torrent client available."
        msg_warn "Install peerflix: npm install -g peerflix"
        msg_warn "Or webtorrent:   npm install -g webtorrent-cli"
        msg_warn "Magnet link: magnet:?xt=urn:btih:${hash}"
    fi
}

# ── Quality picker ────────────────────────────────────────────
select_quality() {
    printf 'best\n1080p\n720p\n480p\n360p' | fzf \
        --prompt="Quality > " --height=10 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7"
}

# ── Play in MPV ───────────────────────────────────────────────
play_stream() {
    local url="$1" title="$2"

    if [[ -z "$url" ]]; then
        msg_err "No stream URL. Cannot play."
        return 1
    fi

    # Handle torrent streams
    if [[ "$url" == torrent:* ]]; then
        local hash file_idx
        hash=$(echo "$url" | cut -d: -f2)
        file_idx=$(echo "$url" | cut -d: -f3)
        play_torrent "$hash" "$file_idx" "$title"
        return $?
    fi

    msg_play "Playing: ${title}"
    printf "${c_dim}    %s${c_rst}\n\n" "$url"

    mpv \
        --title="${title}" \
        --force-window=yes \
        --keep-open=yes \
        --osd-level=1 \
        --save-position-on-quit \
        --user-agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36" \
        "$url"
}

# ── TMDB ──────────────────────────────────────────────────────
tmdb_search()  { curl -sf "${TMDB_BASE}/search/multi?api_key=${TMDB_KEY}&query=$(urlencode "$1")"; }
tmdb_details() { curl -sf "${TMDB_BASE}/${2}/${1}?api_key=${TMDB_KEY}"; }
tmdb_season()  { curl -sf "${TMDB_BASE}/tv/${1}/season/${2}?api_key=${TMDB_KEY}"; }

parse_results() {
    echo "$1" | jq -r '
        .results[] |
        select(.media_type != "person") |
        select(.title != null or .name != null) |
        [ (.media_type // "movie"), (.id|tostring),
          (.title // .name),
          ((.release_date // .first_air_date // "")[0:4]) ] | join("\t")
    ' 2>/dev/null
}

# ── Pickers ───────────────────────────────────────────────────
pick_title() {
    local results="$1" query="$2"
    local fzf_input

    fzf_input=$(echo "$results" | while IFS=$'\t' read -r type id title year; do
        [[ -z "$id" ]] && continue
        local icon="📺"
        [[ "$type" == "movie" ]] && icon="🎬"
        printf "%s\t%s\t%s\t%s %s (%s)\n" "$type" "$id" "$title" "$icon" "$title" "$year"
    done)

    local selected
    selected=$(echo "$fzf_input" | awk -F'\t' '{print $4}' | fzf \
        --prompt="Select > " --height=40 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7" \
        --header="seri-cli — ${query}")
    [[ -z "$selected" ]] && return 1

    echo "$fzf_input" | awk -F'\t' -v s="$selected" '$4==s{print;exit}'
}

pick_episode() {
    local show_id="$1" show_name="$2" total_seasons="$3"

    local season
    season=$(seq 1 "$total_seasons" | awk '{print "Season "$1}' | fzf \
        --prompt="Season > " --height=20 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa,prompt:#89b4fa,pointer:#f5c2e7" \
        --header="$show_name" | grep -oP '\d+')
    [[ -z "$season" ]] && return 1

    local ep_list
    ep_list=$(tmdb_season "$show_id" "$season" | jq -r \
        '.episodes[] | "\(.episode_number). \(.name) (\(.air_date // "TBA"))"' 2>/dev/null)
    [[ -z "$ep_list" ]] && { msg_err "No episodes found."; return 1; }

    local ep_line ep_num
    ep_line=$(echo "$ep_list" | fzf \
        --prompt="Episode > " --height=30 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#a6e3a1,prompt:#a6e3a1,pointer:#f5c2e7" \
        --header="${show_name} — Season ${season}")
    [[ -z "$ep_line" ]] && return 1

    ep_num=$(echo "$ep_line" | grep -oP '^\d+')
    echo "${season}|${ep_num}"
}

what_next() {
    printf 'Replay\nNext episode\nDifferent episode\nQuit' | fzf \
        --prompt="What next > " --height=8 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8,prompt:#f38ba8,pointer:#f5c2e7"
}

# ── Main search & play ────────────────────────────────────────
search_and_play() {
    local query="$1"
    msg_info "Searching: ${query}"

    local json results
    json=$(tmdb_search "$query")

    if [[ -z "$json" ]] || echo "$json" | jq -e '.results | length == 0' &>/dev/null; then
        msg_err "No results found."; return 1
    fi

    results=$(parse_results "$json")
    [[ -z "$results" ]] && { msg_err "No results."; return 1; }

    local row
    row=$(pick_title "$results" "$query")
    [[ $? -ne 0 || -z "$row" ]] && return 0

    local media_type media_id title
    media_type=$(echo "$row" | cut -f1)
    media_id=$(echo "$row"   | cut -f2)
    title=$(echo "$row"      | cut -f3)

    # Get IMDB ID
    msg_info "Fetching IMDB ID…"
    local imdb_id
    imdb_id=$(tmdb_to_imdb "$media_type" "$media_id")
    if [[ -z "$imdb_id" ]]; then
        msg_err "Could not find IMDB ID for: ${title}"
        return 1
    fi
    msg_ok "IMDB ID: ${imdb_id}"

    # Start Stremio if needed
    stremio_start

    local quality
    quality=$(select_quality)
    [[ -z "$quality" ]] && quality="best"

    if [[ "$media_type" == "movie" ]]; then
        msg_info "Fetching streams from Stremio…"
        local streams_json stream
        streams_json=$(stremio_get_streams "movie" "$imdb_id" "" "")
        stream=$(pick_stream_url "$streams_json" "$quality")

        if [[ -z "$stream" ]]; then
            msg_err "No streams found. Make sure Stremio has streaming addons installed."
            msg_warn "Open Stremio → Addons → install 'Torrentio' or 'Public Domain Movies'"
            return 1
        fi

        history_add "movie|${imdb_id}|${title}"
        play_stream "$stream" "$title"

    else
        local details total_seasons
        details=$(tmdb_details "$media_id" "tv")
        total_seasons=$(echo "$details" | jq -r '.number_of_seasons // 1')
        local season ep stream streams_json

        while true; do
            local sep
            sep=$(pick_episode "$media_id" "$title" "$total_seasons")
            [[ $? -ne 0 || -z "$sep" ]] && break

            season=$(echo "$sep" | cut -d'|' -f1)
            ep=$(echo "$sep"     | cut -d'|' -f2)

            msg_info "Fetching streams from Stremio…"
            streams_json=$(stremio_get_streams "series" "$imdb_id" "$season" "$ep")
            stream=$(pick_stream_url "$streams_json" "$quality")

            if [[ -z "$stream" ]]; then
                msg_err "No streams found for S${season}E${ep}."
                msg_warn "Make sure Stremio has Torrentio addon installed."
                continue
            fi

            history_add "tv|${imdb_id}|${title}|S${season}E${ep}"
            play_stream "$stream" "${title} S${season}E${ep}"

            local action
            action=$(what_next)
            case "$action" in
                "Replay")
                    play_stream "$stream" "${title} S${season}E${ep}" ;;
                "Next episode")
                    ep=$((ep + 1))
                    msg_info "Fetching next episode…"
                    streams_json=$(stremio_get_streams "series" "$imdb_id" "$season" "$ep")
                    stream=$(pick_stream_url "$streams_json" "$quality")
                    [[ -n "$stream" ]] && play_stream "$stream" "${title} S${season}E${ep}" ;;
                "Different episode") continue ;;
                *) break ;;
            esac
        done
    fi
}

# ── Update ────────────────────────────────────────────────────
self_update() {
    msg_info "Updating seri-cli…"
    local path
    path=$(command -v seri-cli 2>/dev/null || echo "/usr/local/bin/seri-cli")
    if curl -fsSL \
        "https://raw.githubusercontent.com/lain-iwakura-exe/seri-cli/main/seri-cli" \
        -o /tmp/seri-cli.update; then
        chmod +x /tmp/seri-cli.update
        sudo mv /tmp/seri-cli.update "$path"
        msg_ok "Updated to latest version!"
    else
        msg_err "Update failed."
    fi
}

# ── Help ──────────────────────────────────────────────────────
usage() {
    cat << EOF
${c_bld}seri-cli${c_rst} v${VERSION} — Stream series & films on Linux

${c_bld}USAGE${c_rst}
  seri-cli [OPTIONS] [QUERY]

${c_bld}OPTIONS${c_rst}
  -H, --history     Watch history
  -u, --update      Update seri-cli
  -h, --help        Help
  -v, --version     Version

${c_bld}EXAMPLES${c_rst}
  seri-cli "Breaking Bad"
  seri-cli "Interstellar"
  seri-cli "The Dark Knight"

${c_bld}REQUIRES${c_rst}
  • Stremio installed and set up with addons (Torrentio recommended)
  • curl mpv fzf jq python3
  • Optional: peerflix or webtorrent-cli (for torrent streams)

${c_bld}SETUP${c_rst}
  1. Install Stremio: https://www.stremio.com/downloads
  2. Open Stremio, go to Addons, install Torrentio
  3. Run: seri-cli "Breaking Bad"
EOF
}

# ── Entry ─────────────────────────────────────────────────────
main() {
    dep_check
    init_dirs
    [[ $# -eq 0 ]] && { banner; usage; exit 0; }

    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            -v|--version) echo "seri-cli $VERSION"; exit 0 ;;
            -H|--history) history_show; exit 0 ;;
            -u|--update)  self_update; exit 0 ;;
            -*)           msg_err "Unknown flag: $1"; exit 1 ;;
            *)            query="$*"; break ;;
        esac
    done

    banner

    if [[ -z "$query" ]]; then
        printf "${c_cyn}Search > ${c_rst}"
        read -r query
        [[ -z "$query" ]] && exit 0
    fi

    search_and_play "$query"
}

main "$@"
