#!/usr/bin/env bash
# ============================================================
#  seri-cli v4.5.2 — stream series & films on Linux via MPV
#  NO TORRENTS — Direct streaming from web sources
#  License: GPL-3.0
# ============================================================

VERSION="4.5.2"
QUALITY="${QUALITY:-best}"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/seri-cli/history"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/seri-cli/config"
TMDB_KEY="${TMDB_KEY:-037e92c800c648af4e68b0661944c690}"
TMDB_BASE="https://api.themoviedb.org/3"

c_red='\033[0;31m'; c_grn='\033[0;32m'; c_ylw='\033[1;33m'
c_blu='\033[0;34m'; c_cyn='\033[0;36m'; c_bld='\033[1m'
c_dim='\033[2m';    c_rst='\033[0m'

msg_info() { printf "${c_blu}[~]${c_rst} %s\n" "$*"; }
msg_ok()   { printf "${c_grn}[✓]${c_rst} %s\n" "$*"; }
msg_warn() { printf "${c_ylw}[!]${c_rst} %s\n" "$*"; }
msg_err()  { printf "${c_red}[✗]${c_rst} %s\n" "$*"; }
msg_play() { printf "${c_grn}[▶]${c_rst} ${c_bld}%s${c_rst}\n" "$*"; }

banner() {
    printf "${c_cyn}${c_bld}"
    cat << 'EOF'
  ___  ___ _ __ (_)      ___| (_)
 / __|/ _ \ '__|| |____ / __| | |
 \__ \  __/ |   | |____| (__| | |
 |___/\___|_|   |_|     \___|_|_|
EOF
    printf "${c_rst}${c_dim}  direct streaming • no torrents • v${VERSION}${c_rst}\n\n"
}

dep_check() {
    local missing=()
    for cmd in curl mpv fzf jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        msg_err "Missing dependencies: ${missing[*]}"
        command -v pacman &>/dev/null && echo "  sudo pacman -S ${missing[*]}"
        command -v apt    &>/dev/null && echo "  sudo apt install ${missing[*]}"
        command -v dnf    &>/dev/null && echo "  sudo dnf install ${missing[*]}"
        exit 1
    fi
    if ! command -v yt-dlp &>/dev/null; then
        msg_warn "yt-dlp not found (strongly recommended)"
        msg_info "Install it: sudo apt install yt-dlp"
    fi
}

init_dirs() {
    mkdir -p "$(dirname "$HISTORY_FILE")" "$(dirname "$CONFIG_FILE")"
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"
}

urlencode() {
    local string="$1"
    local strlen=${#string}
    local encoded=""
    local pos c o
    
    for (( pos=0 ; pos<strlen ; pos++ )); do
        c=${string:$pos:1}
        case "$c" in
            [-_.~a-zA-Z0-9] ) o="${c}" ;;
            * ) printf -v o '%%%02x' "'$c" ;;
        esac
        encoded+="${o}"
    done
    echo "$encoded"
}

history_add() { echo "$1" >> "$HISTORY_FILE"; }
history_show() {
    [[ ! -s "$HISTORY_FILE" ]] && { msg_warn "No history yet."; return; }
    printf "${c_cyn}${c_bld}-- Watch History ---------------------${c_rst}\n"
    tac "$HISTORY_FILE" | head -30 | nl -w2 -s'. '
}

# ── TMDB ──────────────────────────────────────────────────────
tmdb_search() {
    curl -sf "${TMDB_BASE}/search/multi?api_key=${TMDB_KEY}&query=$(urlencode "$1")"
}

tmdb_details() {
    curl -sf "${TMDB_BASE}/${2}/${1}?api_key=${TMDB_KEY}"
}

tmdb_season() {
    curl -sf "${TMDB_BASE}/tv/${1}/season/${2}?api_key=${TMDB_KEY}"
}

parse_results() {
    echo "$1" | jq -r '
        .results[] |
        select(.media_type != "person") |
        select(.title != null or .name != null) |
        [ (.media_type // "movie"), (.id|tostring),
          (.title // .name),
          ((.release_date // .first_air_date // "")[0:4]) ] | join("\t")
    ' 2>/dev/null
}

# ── DIRECT STREAMING SCRAPERS ─────────────────────────────────
get_vidsrc_stream() {
    local tmdb_id="$1"
    local type="$2"
    local season="$3"
    local episode="$4"
    
    if [[ "$type" == "movie" ]]; then
        echo "https://vidsrc.to/embed/movie/${tmdb_id}"
    else
        echo "https://vidsrc.to/embed/tv/${tmdb_id}/${season}/${episode}"
    fi
}

get_2embed_stream() {
    local tmdb_id="$1"
    local type="$2"
    local season="$3"
    local episode="$4"
    
    if [[ "$type" == "movie" ]]; then
        echo "https://www.2embed.cc/embed/${tmdb_id}"
    else
        echo "https://www.2embed.cc/embed/${tmdb_id}/${season}/${episode}"
    fi
}

get_vidplay_stream() {
    local tmdb_id="$1"
    local type="$2"
    local season="$3"
    local episode="$4"
    
    if [[ "$type" == "movie" ]]; then
        echo "https://vidplay.online/movie/${tmdb_id}"
    else
        echo "https://vidplay.online/tv/${tmdb_id}/${season}/${episode}"
    fi
}

# Fixed: Returns ONLY the URL, no extra text
get_stream_url() {
    local tmdb_id="$1"
    local type="$2"
    local season="$3"
    local episode="$4"
    
    local sources=(
        "vidsrc:$(get_vidsrc_stream "$tmdb_id" "$type" "$season" "$episode")"
        "2embed:$(get_2embed_stream "$tmdb_id" "$type" "$season" "$episode")"
        "vidplay:$(get_vidplay_stream "$tmdb_id" "$type" "$season" "$episode")"
    )
    
    for source in "${sources[@]}"; do
        local name="${source%%:*}"
        local url="${source#*:}"
        
        msg_info "Trying ${name}..." >&2
        
        # Check if URL is accessible
        if curl -sf --max-time 3 -o /dev/null -w "%{http_code}" "$url" 2>/dev/null | grep -q "200"; then
            msg_ok "Found stream on ${name}" >&2
            echo "$url"
            return 0
        fi
    done
    
    msg_warn "All sources failed" >&2
    return 1
}

# ── Play ──────────────────────────────────────────────────────
play_direct() {
    local url="$1" title="$2"
    
    # Clean URL - remove any extra text, keep only the URL
    url=$(echo "$url" | grep -o 'https://[^ ]*' | head -1)
    
    if [[ -z "$url" ]]; then
        msg_err "Invalid URL"
        return 1
    fi
    
    msg_play "Playing: ${title}"
    msg_info "Press 'q' to quit, 'space' to pause"
    
    # Use yt-dlp to extract the actual video stream
    if command -v yt-dlp &>/dev/null; then
        mpv \
            --ytdl \
            --title="${title}" \
            --force-window=yes \
            --keep-open=yes \
            --osd-level=1 \
            --save-position-on-quit \
            --cache=yes \
            --cache-secs=300 \
            --force-seekable=yes \
            --hls-bitrate=max \
            "$url"
    else
        msg_warn "yt-dlp not found - trying direct"
        mpv \
            --title="${title}" \
            --force-window=yes \
            --keep-open=yes \
            --osd-level=1 \
            --save-position-on-quit \
            --cache=yes \
            --cache-secs=300 \
            --force-seekable=yes \
            --user-agent="Mozilla/5.0" \
            --referrer="https://vidsrc.to/" \
            "$url"
    fi
    
    return $?
}

# ── Main search and play ─────────────────────────────────────
search_and_play() {
    local query="$1"
    msg_info "Searching: ${query}"

    local json results
    json=$(tmdb_search "$query")

    if [[ -z "$json" ]] || echo "$json" | jq -e '.results | length == 0' &>/dev/null; then
        msg_err "No results found."
        return 1
    fi

    results=$(parse_results "$json")
    [[ -z "$results" ]] && { msg_err "No results."; return 1; }

    local row
    row=$(pick_title "$results" "$query")
    [[ $? -ne 0 || -z "$row" ]] && return 0

    local media_type media_id title
    media_type=$(echo "$row" | cut -f1)
    media_id=$(echo "$row"   | cut -f2)
    title=$(echo "$row"      | cut -f3)

    msg_info "Getting stream for: ${title}"

    if [[ "$media_type" == "movie" ]]; then
        local stream_url
        stream_url=$(get_stream_url "$media_id" "movie" "" "")
        
        if [[ -n "$stream_url" ]]; then
            history_add "movie|${media_id}|${title}"
            play_direct "$stream_url" "$title"
        else
            msg_err "Could not find any working stream for: ${title}"
        fi

    else
        local details total_seasons
        details=$(tmdb_details "$media_id" "tv")
        total_seasons=$(echo "$details" | jq -r '.number_of_seasons // 1')
        local season ep stream_url

        while true; do
            local sep
            sep=$(pick_episode "$media_id" "$title" "$total_seasons")
            [[ $? -ne 0 || -z "$sep" ]] && break

            season=$(echo "$sep" | cut -d'|' -f1)
            ep=$(echo "$sep"     | cut -d'|' -f2)

            msg_info "Getting stream for: ${title} S${season}E${ep}"
            stream_url=$(get_stream_url "$media_id" "tv" "$season" "$ep")
            
            if [[ -n "$stream_url" ]]; then
                history_add "tv|${media_id}|${title}|S${season}E${ep}"
                play_direct "$stream_url" "${title} S${season}E${ep}"
            else
                msg_err "Could not find stream for ${title} S${season}E${ep}"
            fi

            local action
            action=$(what_next)
            case "$action" in
                "Replay")
                    play_direct "$stream_url" "${title} S${season}E${ep}" ;;
                "Next episode")
                    ep=$((ep + 1))
                    msg_info "Getting next episode..."
                    stream_url=$(get_stream_url "$media_id" "tv" "$season" "$ep")
                    play_direct "$stream_url" "${title} S${season}E${ep}" ;;
                "Different episode") continue ;;
                *) break ;;
            esac
        done
    fi
}

# ── Pickers ───────────────────────────────────────────────────
pick_title() {
    local results="$1" query="$2"
    local fzf_input

    fzf_input=$(echo "$results" | while IFS=$'\t' read -r type id title year; do
        [[ -z "$id" ]] && continue
        local icon="[TV]"
        [[ "$type" == "movie" ]] && icon="[Movie]"
        printf "%s\t%s\t%s\t%s %s (%s)\n" "$type" "$id" "$title" "$icon" "$title" "$year"
    done)

    local selected
    selected=$(echo "$fzf_input" | awk -F'\t' '{print $4}' | fzf \
        --prompt="Select > " --height=40 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7" \
        --header="seri-cli -- ${query}")
    [[ -z "$selected" ]] && return 1

    echo "$fzf_input" | awk -F'\t' -v s="$selected" '$4==s{print;exit}'
}

pick_episode() {
    local show_id="$1" show_name="$2" total_seasons="$3"

    local season
    season=$(seq 1 "$total_seasons" | awk '{print "Season "$1}' | fzf \
        --prompt="Season > " --height=20 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa,prompt:#89b4fa,pointer:#f5c2e7" \
        --header="$show_name" | grep -oP '\d+')
    [[ -z "$season" ]] && return 1

    local ep_list
    ep_list=$(tmdb_season "$show_id" "$season" | jq -r \
        '.episodes[] | "\(.episode_number). \(.name) (\(.air_date // "TBA"))"' 2>/dev/null)
    [[ -z "$ep_list" ]] && { msg_err "No episodes found."; return 1; }

    local ep_line ep_num
    ep_line=$(echo "$ep_list" | fzf \
        --prompt="Episode > " --height=30 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#a6e3a1,prompt:#a6e3a1,pointer:#f5c2e7" \
        --header="${show_name} -- Season ${season}")
    [[ -z "$ep_line" ]] && return 1

    ep_num=$(echo "$ep_line" | grep -oP '^\d+')
    echo "${season}|${ep_num}"
}

what_next() {
    printf 'Replay\nNext episode\nDifferent episode\nQuit' | fzf \
        --prompt="What next > " --height=8 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8,prompt:#f38ba8,pointer:#f5c2e7"
}

# ── Self Update ──────────────────────────────────────────────
self_update() {
    msg_info "Updating seri-cli..."
    local path
    path=$(command -v seri-cli 2>/dev/null || echo "/usr/local/bin/seri-cli")
    if curl -fsSL \
        "https://raw.githubusercontent.com/lain-iwakura-exe/seri-cli/main/seri-cli" \
        -o /tmp/seri-cli.update; then
        chmod +x /tmp/seri-cli.update
        sudo mv /tmp/seri-cli.update "$path"
        msg_ok "Updated to latest version!"
    else
        msg_err "Update failed."
    fi
}

# ── Usage ─────────────────────────────────────────────────────
usage() {
    cat << EOF
${c_bld}seri-cli${c_rst} v${VERSION} -- Stream series & films on Linux

${c_bld}USAGE${c_rst}
  seri-cli [OPTIONS] [QUERY]

${c_bld}OPTIONS${c_rst}
  -H, --history     Watch history
  -u, --update      Update seri-cli
  -h, --help        Help
  -v, --version     Version

${c_bld}EXAMPLES${c_rst}
  seri-cli "Breaking Bad"
  seri-cli "Interstellar"
  seri-cli "The Dark Knight"

${c_bld}DEPS${c_rst}
  Required: curl mpv fzf jq
  Recommended: yt-dlp (sudo apt install yt-dlp)

${c_bld}STREAM SOURCES${c_rst}
  vidsrc.to, 2embed.cc, vidplay.online
  No torrents, no peerflix, no npm!
EOF
}

# ── Main ──────────────────────────────────────────────────────
main() {
    dep_check
    init_dirs
    [[ $# -eq 0 ]] && { banner; usage; exit 0; }

    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            -v|--version) echo "seri-cli $VERSION"; exit 0 ;;
            -H|--history) history_show; exit 0 ;;
            -u|--update)  self_update; exit 0 ;;
            -*)           msg_err "Unknown flag: $1"; exit 1 ;;
            *)            query="$*"; break ;;
        esac
    done

    banner

    if [[ -z "$query" ]]; then
        printf "${c_cyn}Search > ${c_rst}"
        read -r query
        [[ -z "$query" ]] && exit 0
    fi

    search_and_play "$query"
}

main "$@"