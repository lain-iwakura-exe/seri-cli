#!/usr/bin/env bash
# ============================================================
#  seri-cli — stream series, movies & films in MPV on Linux
#  Inspired by ani-cli | Works on any Linux distro
#  License: GPL-3.0
# ============================================================

VERSION="2.0.0"
PLAYER="${PLAYER:-mpv}"
QUALITY="${QUALITY:-best}"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/seri-cli/history"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/seri-cli/config"
TMDB_KEY="${TMDB_KEY:-037e92c800c648af4e68b0661944c690}"
TMDB_BASE="https://api.themoviedb.org/3"

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
BLU='\033[0;34m'
CYN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RST='\033[0m'

banner() {
    printf "${CYN}${BOLD}"
    cat << 'EOF'
  ___  ___ _ __ (_)      ___| (_)
 / __|/ _ \ '__|| |____ / __| | |
 \__ \  __/ |   | |____| (__| | |
 |___/\___|_|   |_|     \___|_|_|
EOF
    printf "${RST}${DIM}  stream series & films on Linux  v${VERSION}${RST}\n\n"
}

# ── Dependency check ──────────────────────────────────────────
dep_check() {
    local missing=()
    for cmd in curl mpv fzf jq python3; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        printf "${RED}[!] Missing: ${missing[*]}${RST}\n"
        if command -v pacman &>/dev/null; then
            printf "${YLW}    sudo pacman -S ${missing[*]}${RST}\n"
        elif command -v apt &>/dev/null; then
            printf "${YLW}    sudo apt install ${missing[*]}${RST}\n"
        fi
        exit 1
    fi
}

# ── Init dirs ─────────────────────────────────────────────────
init_dirs() {
    mkdir -p "$(dirname "$HISTORY_FILE")" "$(dirname "$CONFIG_FILE")"
    [[ -f "$CONFIG_FILE" ]] || cat > "$CONFIG_FILE" << 'CONF'
# seri-cli config
# TMDB_KEY=your_key_here
# QUALITY=best   # best | 1080p | 720p | 480p | 360p
# PLAYER=mpv
CONF
}

[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# ── History ───────────────────────────────────────────────────
history_add() {
    echo "$1" >> "$HISTORY_FILE"
    tac "$HISTORY_FILE" | awk '!seen[$0]++' | head -100 | tac > "${HISTORY_FILE}.tmp"
    mv "${HISTORY_FILE}.tmp" "$HISTORY_FILE"
}

history_show() {
    [[ ! -s "$HISTORY_FILE" ]] && { printf "${YLW}No history yet.${RST}\n"; return; }
    printf "${CYN}${BOLD}── Watch History ──────────────────────${RST}\n"
    tac "$HISTORY_FILE" | head -30 | nl -w2 -s'. '
}

# ── URL encode ────────────────────────────────────────────────
urlencode() {
    python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$1"
}

# ── TMDB ─────────────────────────────────────────────────────
tmdb_search() {
    curl -sf "${TMDB_BASE}/search/multi?api_key=${TMDB_KEY}&query=$(urlencode "$1")&page=1"
}

tmdb_details() {
    curl -sf "${TMDB_BASE}/${2}/${1}?api_key=${TMDB_KEY}"
}

tmdb_season() {
    curl -sf "${TMDB_BASE}/tv/${1}/season/${2}?api_key=${TMDB_KEY}"
}

# ── Parse search results ──────────────────────────────────────
parse_results() {
    echo "$1" | jq -r '
        .results[] |
        select(.media_type != "person") |
        select(.title != null or .name != null) |
        [
          (.media_type // "movie"),
          (.id | tostring),
          (.title // .name),
          ((.release_date // .first_air_date // "")[0:4])
        ] | join("|||")
    ' 2>/dev/null
}

# ── Stream extraction ─────────────────────────────────────────
# We try multiple methods in order until one works

# Method 1: 2embed (most scraper-friendly)
get_2embed_url() {
    local type="$1" id="$2" season="$3" ep="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://www.2embed.cc/embed/${id}"
    else
        echo "https://www.2embed.cc/embedtv/${id}&s=${season}&e=${ep}"
    fi
}

# Method 2: vidsrc.me (different from vidsrc.to, more open)
get_vidsrcme_url() {
    local type="$1" id="$2" season="$3" ep="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://vidsrc.me/embed/movie?tmdb=${id}"
    else
        echo "https://vidsrc.me/embed/tv?tmdb=${id}&season=${season}&episode=${ep}"
    fi
}

# Method 3: superembed
get_superembed_url() {
    local type="$1" id="$2" season="$3" ep="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://multiembed.mov/directstream.php?video_id=${id}&tmdb=1"
    else
        echo "https://multiembed.mov/directstream.php?video_id=${id}&tmdb=1&s=${season}&e=${ep}"
    fi
}

# Method 4: embedsu
get_embedsu_url() {
    local type="$1" id="$2" season="$3" ep="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://embed.su/embed/movie/${id}"
    else
        echo "https://embed.su/embed/tv/${id}/${season}/${ep}"
    fi
}

# Try to extract direct stream URL using yt-dlp
try_ytdlp() {
    local url="$1"
    command -v yt-dlp &>/dev/null || return 1
    local result
    result=$(yt-dlp --no-warnings --no-check-certificate \
        -f "bestvideo+bestaudio/best" \
        -g "$url" 2>/dev/null | head -1)
    [[ -n "$result" ]] && echo "$result"
}

# Try to scrape m3u8 from page source directly
try_scrape_m3u8() {
    local url="$1"
    local page
    page=$(curl -sf --max-time 10 \
        -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36" \
        -H "Referer: https://www.google.com/" \
        "$url" 2>/dev/null)
    # Look for m3u8 URLs in page source
    local m3u8
    m3u8=$(echo "$page" | grep -oP 'https?://[^"'"'"'\s]+\.m3u8[^"'"'"'\s]*' | head -1)
    [[ -n "$m3u8" ]] && echo "$m3u8" && return 0
    # Look for mp4 URLs
    local mp4
    mp4=$(echo "$page" | grep -oP 'https?://[^"'"'"'\s]+\.mp4[^"'"'"'\s]*' | head -1)
    [[ -n "$mp4" ]] && echo "$mp4"
}

# Try using mpv's own youtube-dl hook with extra options
try_mpv_direct() {
    local url="$1"
    echo "$url"  # just return the URL, mpv will try
}

# Main stream resolver — tries all methods
resolve_stream() {
    local type="$1" id="$2" season="$3" ep="$4"
    local stream=""

    printf "${BLU}[~]${RST} Trying embed.su…\n"
    local url4
    url4=$(get_embedsu_url "$type" "$id" "$season" "$ep")
    stream=$(try_ytdlp "$url4")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    stream=$(try_scrape_m3u8 "$url4")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    printf "${BLU}[~]${RST} Trying vidsrc.me…\n"
    local url2
    url2=$(get_vidsrcme_url "$type" "$id" "$season" "$ep")
    stream=$(try_ytdlp "$url2")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    stream=$(try_scrape_m3u8 "$url2")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    printf "${BLU}[~]${RST} Trying 2embed…\n"
    local url1
    url1=$(get_2embed_url "$type" "$id" "$season" "$ep")
    stream=$(try_ytdlp "$url1")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    stream=$(try_scrape_m3u8 "$url1")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    printf "${BLU}[~]${RST} Trying multiembed direct…\n"
    local url3
    url3=$(get_superembed_url "$type" "$id" "$season" "$ep")
    stream=$(try_ytdlp "$url3")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    stream=$(try_scrape_m3u8 "$url3")
    [[ -n "$stream" ]] && echo "$stream" && return 0

    # Last resort: pass embed URL directly to mpv
    printf "${YLW}[!]${RST} Falling back to direct embed in MPV…\n"
    echo "$url2"
}

# ── Quality ───────────────────────────────────────────────────
select_quality() {
    printf 'best\n1080p\n720p\n480p\n360p' | fzf \
        --prompt="Quality ❯ " --height=10 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7"
}

quality_fmt() {
    case "$1" in
        1080p) echo "bestvideo[height<=1080]+bestaudio/best[height<=1080]" ;;
        720p)  echo "bestvideo[height<=720]+bestaudio/best[height<=720]" ;;
        480p)  echo "bestvideo[height<=480]+bestaudio/best[height<=480]" ;;
        360p)  echo "bestvideo[height<=360]+bestaudio/best[height<=360]" ;;
        *)     echo "bestvideo+bestaudio/best" ;;
    esac
}

# ── Play in MPV ───────────────────────────────────────────────
play_stream() {
    local url="$1" title="$2" quality="${3:-best}"
    printf "${GRN}[▶]${RST} Playing: ${BOLD}${title}${RST}\n\n"

    local mpv_args=(
        --title="${title}"
        --force-window=yes
        --keep-open=yes
        --osd-level=1
        --save-position-on-quit
        --no-terminal
    )

    if command -v yt-dlp &>/dev/null; then
        mpv_args+=(--ytdl-format="$(quality_fmt "$quality")")
    fi

    mpv "${mpv_args[@]}" "$url" 2>/dev/null
    return $?
}

# ── Episode picker ────────────────────────────────────────────
pick_episode() {
    local show_id="$1" show_name="$2" total_seasons="$3"

    local season
    season=$(seq 1 "$total_seasons" | awk '{print "Season "$1}' | fzf \
        --prompt="Season ❯ " --height=20 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa,prompt:#89b4fa,pointer:#f5c2e7" \
        --header="📺 ${show_name}" | grep -oP '\d+')
    [[ -z "$season" ]] && return 1

    local season_json ep_list
    season_json=$(tmdb_season "$show_id" "$season")
    ep_list=$(echo "$season_json" | jq -r \
        '.episodes[] | "\(.episode_number). \(.name) (\(.air_date // "TBA"))"' 2>/dev/null)
    [[ -z "$ep_list" ]] && { printf "${RED}[!] No episodes found.${RST}\n"; return 1; }

    local ep_line ep_num
    ep_line=$(echo "$ep_list" | fzf \
        --prompt="Episode ❯ " --height=30 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#a6e3a1,prompt:#a6e3a1,pointer:#f5c2e7" \
        --header="📺 ${show_name} — Season ${season}")
    [[ -z "$ep_line" ]] && return 1

    ep_num=$(echo "$ep_line" | grep -oP '^\d+')
    echo "${season}|${ep_num}"
}

# ── What next menu ────────────────────────────────────────────
what_next() {
    printf '\nReplay\nNext episode\nDifferent episode\nQuit' | fzf \
        --prompt="What next ❯ " --height=10 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8,prompt:#f38ba8,pointer:#f5c2e7"
}

# ── Main search & play ────────────────────────────────────────
search_and_play() {
    local query="$1"
    printf "${BLU}[~]${RST} Searching: ${BOLD}${query}${RST}\n"

    local json results
    json=$(tmdb_search "$query")

    if [[ -z "$json" ]] || echo "$json" | jq -e '.results | length == 0' &>/dev/null; then
        printf "${RED}[!] No results found.${RST}\n"; return 1
    fi

    results=$(parse_results "$json")
    [[ -z "$results" ]] && { printf "${RED}[!] No results.${RST}\n"; return 1; }

    # Build fzf list
    local fzf_input
    fzf_input=$(echo "$results" | awk -F'|||' '{
        type=$1; id=$2; title=$3; year=$4
        icon=(type=="movie") ? "🎬" : "📺"
        printf "%s %s (%s) [%s]|||%s|||%s|||%s\n", icon, title, year, type, type, id, title
    }')

    local selected
    selected=$(echo "$fzf_input" | awk -F'|||' '{print $1}' | fzf \
        --prompt="Select ❯ " --height=40 --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7" \
        --header="seri-cli — results for: ${query}")
    [[ -z "$selected" ]] && return 0

    local row media_type media_id title
    row=$(echo "$fzf_input" | grep -F "${selected}|||" | head -1)
    media_type=$(echo "$row" | awk -F'|||' '{print $2}')
    media_id=$(echo "$row" | awk -F'|||' '{print $3}')
    title=$(echo "$row" | awk -F'|||' '{print $4}')

    local quality
    quality=$(select_quality)
    [[ -z "$quality" ]] && quality="best"

    if [[ "$media_type" == "movie" ]]; then
        printf "${CYN}[→]${RST} Resolving stream for: ${BOLD}${title}${RST}\n"
        local stream
        stream=$(resolve_stream "movie" "$media_id" "" "")
        history_add "movie|||${media_id}|||${title}"
        play_stream "$stream" "$title" "$quality"

    else
        local details total_seasons
        details=$(tmdb_details "$media_id" "tv")
        total_seasons=$(echo "$details" | jq -r '.number_of_seasons // 1')

        local current_season current_ep stream

        while true; do
            local sep
            sep=$(pick_episode "$media_id" "$title" "$total_seasons")
            [[ $? -ne 0 || -z "$sep" ]] && break

            current_season=$(echo "$sep" | cut -d'|' -f1)
            current_ep=$(echo "$sep" | cut -d'|' -f2)

            printf "${CYN}[→]${RST} Resolving stream…\n"
            stream=$(resolve_stream "tv" "$media_id" "$current_season" "$current_ep")
            history_add "tv|||${media_id}|||${title}|||S${current_season}E${current_ep}"
            play_stream "$stream" "${title} S${current_season}E${current_ep}" "$quality"

            local action
            action=$(what_next)

            case "$action" in
                "Replay")
                    play_stream "$stream" "${title} S${current_season}E${current_ep}" "$quality"
                    ;;
                "Next episode")
                    current_ep=$((current_ep + 1))
                    printf "${CYN}[→]${RST} Resolving next episode…\n"
                    stream=$(resolve_stream "tv" "$media_id" "$current_season" "$current_ep")
                    history_add "tv|||${media_id}|||${title}|||S${current_season}E${current_ep}"
                    play_stream "$stream" "${title} S${current_season}E${current_ep}" "$quality"
                    ;;
                "Different episode") continue ;;
                *) break ;;
            esac
        done
    fi
}

# ── Update ────────────────────────────────────────────────────
self_update() {
    local path
    path=$(command -v seri-cli 2>/dev/null || echo "/usr/local/bin/seri-cli")
    printf "${BLU}[~]${RST} Updating seri-cli…\n"
    if curl -fsSL "https://raw.githubusercontent.com/lain-iwakura-exe/seri-cli/main/seri-cli" \
        -o "/tmp/seri-cli.update" 2>/dev/null; then
        chmod +x "/tmp/seri-cli.update"
        sudo mv "/tmp/seri-cli.update" "$path"
        printf "${GRN}[✓]${RST} Updated!\n"
    else
        printf "${RED}[!] Update failed.${RST}\n"
    fi
}

# ── Help ──────────────────────────────────────────────────────
usage() {
    cat << EOF
${BOLD}seri-cli${RST} v${VERSION} — Stream series & films on Linux

${BOLD}USAGE${RST}
  seri-cli [OPTIONS] [QUERY]

${BOLD}OPTIONS${RST}
  -q, --quality     Pick quality interactively
  -H, --history     Show watch history
  -u, --update      Update seri-cli
  -h, --help        Show help
  -v, --version     Show version

${BOLD}EXAMPLES${RST}
  seri-cli "Breaking Bad"
  seri-cli "The Dark Knight"
  seri-cli -q "Chernobyl"

${BOLD}DEPS${RST}
  Required : curl mpv fzf jq python3
  Optional : yt-dlp
EOF
}

# ── Entry point ───────────────────────────────────────────────
main() {
    dep_check
    init_dirs

    [[ $# -eq 0 ]] && { banner; usage; exit 0; }

    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage; exit 0 ;;
            -v|--version) echo "seri-cli $VERSION"; exit 0 ;;
            -H|--history) history_show; exit 0 ;;
            -u|--update)  self_update; exit 0 ;;
            -q|--quality) QUALITY=$(select_quality); shift ;;
            -*)           printf "${RED}Unknown flag: $1${RST}\n"; exit 1 ;;
            *)            query="$*"; break ;;
        esac
    done

    banner

    if [[ -z "$query" ]]; then
        printf "${CYN}Search ❯${RST} "
        read -r query
        [[ -z "$query" ]] && exit 0
    fi

    search_and_play "$query"
}

main "$@"
