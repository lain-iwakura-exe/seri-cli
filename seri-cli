#!/usr/bin/env bash
# ============================================================
#  seri-cli — stream series, movies & films in MPV on Linux
#  Inspired by ani-cli | Works on Arch/CachyOS/EndeavourOS
#  License: GPL-3.0
# ============================================================

VERSION="1.0.0"
PLAYER="${PLAYER:-mpv}"
PROVIDER="${PROVIDER:-vidsrc}"   # primary provider
QUALITY="${QUALITY:-best}"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/seri-cli/history"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/seri-cli/config"

# ── Colors ────────────────────────────────────────────────────
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
BLU='\033[0;34m'
CYN='\033[0;36m'
MAG='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
RST='\033[0m'

# ── Banner ────────────────────────────────────────────────────
banner() {
    printf "${CYN}${BOLD}"
    cat << 'EOF'
  ___  ___ _ __ (_)      ___| (_)
 / __|/ _ \ '__|| |____ / __| | |
 \__ \  __/ |   | |____| (__| | |
 |___/\___|_|   |_|     \___|_|_|
EOF
    printf "${RST}${DIM}  stream series & films on Linux  v${VERSION}${RST}\n\n"
}

# ── Dependencies check ────────────────────────────────────────
dep_check() {
    local missing=()
    for cmd in curl mpv fzf jq; do
        command -v "$cmd" &>/dev/null || missing+=("$cmd")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        printf "${RED}[!] Missing dependencies: ${missing[*]}${RST}\n"
        printf "${YLW}    Install with: sudo pacman -S ${missing[*]}${RST}\n"
        exit 1
    fi
}

# ── Config / History helpers ──────────────────────────────────
init_dirs() {
    mkdir -p "$(dirname "$HISTORY_FILE")"
    mkdir -p "$(dirname "$CONFIG_FILE")"
    [[ -f "$CONFIG_FILE" ]] || cat > "$CONFIG_FILE" << 'CONF'
# seri-cli config
# PROVIDER=vidsrc          # vidsrc | vidsrcpro | multiembed
# QUALITY=best             # best | 1080 | 720 | 480 | 360
# PLAYER=mpv
CONF
}

# Source config if exists
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

history_add() {
    local entry="$1"
    echo "$entry" >> "$HISTORY_FILE"
    # keep last 100 entries unique
    tac "$HISTORY_FILE" | awk '!seen[$0]++' | head -100 | tac > "${HISTORY_FILE}.tmp"
    mv "${HISTORY_FILE}.tmp" "$HISTORY_FILE"
}

history_show() {
    if [[ ! -f "$HISTORY_FILE" ]] || [[ ! -s "$HISTORY_FILE" ]]; then
        printf "${YLW}No watch history yet.${RST}\n"; return
    fi
    printf "${CYN}${BOLD}── Watch History ──────────────────────${RST}\n"
    tac "$HISTORY_FILE" | head -30 | nl -w2 -s'. '
}

# ── TMDB Search (free, no key needed via unofficial proxy) ────
# Uses the public TMDB v3 mirror / open endpoints
TMDB_BASE="https://api.themoviedb.org/3"
# We use a community-shared free TMDB read key (public tier, rate-limited)
# Users can override with their own in config: TMDB_KEY=...
TMDB_KEY="${TMDB_KEY:-4f4086a43f618f89e89bca8a4d9cd3ce}"

tmdb_search() {
    local query="$1" type="${2:-multi}"   # multi | movie | tv
    local url="${TMDB_BASE}/search/${type}?api_key=${TMDB_KEY}&query=$(python3 -c "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" "$query")&page=1"
    curl -sf "$url" 2>/dev/null
}

tmdb_details() {
    local id="$1" type="$2"   # movie | tv
    curl -sf "${TMDB_BASE}/${type}/${id}?api_key=${TMDB_KEY}" 2>/dev/null
}

tmdb_seasons() {
    local id="$1" season="$2"
    curl -sf "${TMDB_BASE}/tv/${id}/season/${season}?api_key=${TMDB_KEY}" 2>/dev/null
}

# ── Parse search results into selectable list ─────────────────
parse_results() {
    local json="$1"
    # returns: "TYPE|ID|TITLE|YEAR"
    echo "$json" | jq -r '
        .results[] |
        select(.media_type != "person") |
        [
          (.media_type // "movie"),
          (.id | tostring),
          (.title // .name),
          ((.release_date // .first_air_date // "")[0:4])
        ] | join("|")
    ' 2>/dev/null
}

# ── Stream URL providers ──────────────────────────────────────
# These are public embed providers that ani-cli-style tools commonly use.
# seri-cli extracts the direct stream URL via yt-dlp or direct scrape.

get_vidsrc_url() {
    local type="$1" id="$2" season="$3" episode="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://vidsrc.to/embed/movie/${id}"
    else
        echo "https://vidsrc.to/embed/tv/${id}/${season}/${episode}"
    fi
}

get_multiembed_url() {
    local type="$1" id="$2" season="$3" episode="$4"
    if [[ "$type" == "movie" ]]; then
        echo "https://multiembed.mov/?video_id=${id}&tmdb=1"
    else
        echo "https://multiembed.mov/?video_id=${id}&tmdb=1&s=${season}&e=${episode}"
    fi
}

# ── Try to extract direct m3u8/mp4 via yt-dlp ─────────────────
extract_stream() {
    local embed_url="$1"
    if command -v yt-dlp &>/dev/null; then
        local stream
        stream=$(yt-dlp --no-warnings -g "$embed_url" 2>/dev/null | head -1)
        [[ -n "$stream" ]] && echo "$stream" && return 0
    fi
    # Fallback: pass embed URL directly to mpv (it handles many embeds natively)
    echo "$embed_url"
}

# ── Quality selection ─────────────────────────────────────────
select_quality() {
    local choices=("best" "1080p" "720p" "480p" "360p")
    local selected
    selected=$(printf '%s\n' "${choices[@]}" | fzf \
        --prompt="Quality ❯ " \
        --height=10 \
        --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7")
    echo "${selected:-best}"
}

# ── MPV quality flag mapping ──────────────────────────────────
quality_to_ytdlp_format() {
    case "$1" in
        1080p) echo "bestvideo[height<=1080]+bestaudio/best[height<=1080]" ;;
        720p)  echo "bestvideo[height<=720]+bestaudio/best[height<=720]" ;;
        480p)  echo "bestvideo[height<=480]+bestaudio/best[height<=480]" ;;
        360p)  echo "bestvideo[height<=360]+bestaudio/best[height<=360]" ;;
        *)     echo "bestvideo+bestaudio/best" ;;
    esac
}

# ── Launch MPV ────────────────────────────────────────────────
play_in_mpv() {
    local url="$1" title="$2" quality="${3:-best}"
    local fmt
    fmt=$(quality_to_ytdlp_format "$quality")

    printf "${GRN}[▶]${RST} Playing: ${BOLD}${title}${RST}\n"
    printf "${DIM}    Quality: ${quality} | Provider: ${PROVIDER}${RST}\n\n"

    local mpv_args=(
        --title="${title}"
        --force-window=yes
        --keep-open=yes
        --osd-level=1
        --save-position-on-quit
    )

    # If yt-dlp is available and URL is an embed, use it for quality control
    if command -v yt-dlp &>/dev/null && [[ "$url" == *"embed"* || "$url" == *"tmdb"* ]]; then
        mpv_args+=(--ytdl-format="$fmt")
    fi

    mpv "${mpv_args[@]}" "$url"
}

# ── Interactive episode picker ────────────────────────────────
pick_episode() {
    local show_id="$1" show_name="$2" total_seasons="$3"

    # Pick season
    local season
    season=$(seq 1 "$total_seasons" | awk '{print "Season "$1}' | fzf \
        --prompt="Season ❯ " \
        --height=20 \
        --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#89b4fa,prompt:#89b4fa,pointer:#f5c2e7" \
        --header="📺 ${show_name}" | grep -oP '\d+')

    [[ -z "$season" ]] && return 1

    # Fetch episodes for this season
    local season_json ep_list
    season_json=$(tmdb_seasons "$show_id" "$season")
    ep_list=$(echo "$season_json" | jq -r '
        .episodes[] | "\(.episode_number). \(.name) (\(.air_date // "TBA"))"
    ' 2>/dev/null)

    [[ -z "$ep_list" ]] && { printf "${RED}[!] Could not fetch episodes.${RST}\n"; return 1; }

    local ep_line ep_num
    ep_line=$(echo "$ep_list" | fzf \
        --prompt="Episode ❯ " \
        --height=30 \
        --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#a6e3a1,prompt:#a6e3a1,pointer:#f5c2e7" \
        --header="📺 ${show_name} — Season ${season}")

    [[ -z "$ep_line" ]] && return 1
    ep_num=$(echo "$ep_line" | grep -oP '^\d+')

    echo "${season}|${ep_num}"
}

# ── Main search & play flow ───────────────────────────────────
search_and_play() {
    local query="$1"

    printf "${BLU}[~]${RST} Searching for: ${BOLD}${query}${RST}\n"

    local search_json results_raw
    search_json=$(tmdb_search "$query" "multi")

    if [[ -z "$search_json" ]] || echo "$search_json" | jq -e '.results | length == 0' &>/dev/null; then
        printf "${RED}[!] No results found.${RST}\n"
        return 1
    fi

    results_raw=$(parse_results "$search_json")
    [[ -z "$results_raw" ]] && { printf "${RED}[!] No streamable results.${RST}\n"; return 1; }

    # Build fzf display list: "TITLE (YEAR) [TYPE]"
    local fzf_list
    fzf_list=$(echo "$results_raw" | awk -F'|' '{
        type = $1; id = $2; title = $3; year = $4
        icon = (type=="movie") ? "🎬" : "📺"
        printf "%s %s (%s) [%s]|%s|%s|%s\n", icon, title, year, type, type, id, title
    }')

    local selected
    selected=$(echo "$fzf_list" | awk -F'|' '{print $1}' | fzf \
        --prompt="Select ❯ " \
        --height=40 \
        --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,prompt:#cba6f7,pointer:#f5c2e7,header:#89dceb" \
        --header="🎬 seri-cli — $(echo "$fzf_list" | wc -l) results" \
        --no-sort)

    [[ -z "$selected" ]] && return 1

    # Find matching row
    local row
    row=$(echo "$fzf_list" | grep -F "${selected}|" | head -1)
    local media_type media_id title
    media_type=$(echo "$row" | cut -d'|' -f2)
    media_id=$(echo "$row" | cut -d'|' -f3)
    title=$(echo "$row" | cut -d'|' -f4)

    # Quality selection
    local quality
    quality=$(select_quality)

    local embed_url stream_url season_ep

    if [[ "$media_type" == "movie" ]]; then
        embed_url=$(get_vidsrc_url "movie" "$media_id" "" "")
        printf "${CYN}[→]${RST} Fetching stream for movie: ${BOLD}${title}${RST}\n"
        stream_url=$(extract_stream "$embed_url")
        history_add "movie|${media_id}|${title}"
        play_in_mpv "$stream_url" "$title" "$quality"

    else
        # TV show — get total seasons
        local details total_seasons
        details=$(tmdb_details "$media_id" "tv")
        total_seasons=$(echo "$details" | jq -r '.number_of_seasons // 1')

        while true; do
            season_ep=$(pick_episode "$media_id" "$title" "$total_seasons")
            [[ $? -ne 0 ]] && break

            local season episode
            season=$(echo "$season_ep" | cut -d'|' -f1)
            episode=$(echo "$season_ep" | cut -d'|' -f2)

            embed_url=$(get_vidsrc_url "tv" "$media_id" "$season" "$episode")
            printf "${CYN}[→]${RST} Fetching stream…\n"
            stream_url=$(extract_stream "$embed_url")

            history_add "tv|${media_id}|${title}|S${season}E${episode}"
            play_in_mpv "$stream_url" "${title} S${season}E${episode}" "$quality"

            # After playback: replay / next / exit
            printf "\n${YLW}${BOLD}What next?${RST}\n"
            local action
            action=$(printf 'Replay\nNext episode\nDifferent episode\nQuit' | fzf \
                --prompt="Action ❯ " \
                --height=10 \
                --border=rounded \
                --color="fg:#cdd6f4,bg:#1e1e2e,hl:#f38ba8,prompt:#f38ba8,pointer:#f5c2e7")

            case "$action" in
                "Replay")
                    play_in_mpv "$stream_url" "${title} S${season}E${episode}" "$quality"
                    ;;
                "Next episode")
                    episode=$((episode + 1))
                    embed_url=$(get_vidsrc_url "tv" "$media_id" "$season" "$episode")
                    stream_url=$(extract_stream "$embed_url")
                    history_add "tv|${media_id}|${title}|S${season}E${episode}"
                    play_in_mpv "$stream_url" "${title} S${season}E${episode}" "$quality"
                    ;;
                "Different episode") continue ;;
                *) break ;;
            esac
        done
    fi
}

# ── Provider switcher ─────────────────────────────────────────
switch_provider() {
    local p
    p=$(printf 'vidsrc\nmultiembed\nvidsrcpro' | fzf \
        --prompt="Provider ❯ " \
        --height=8 \
        --border=rounded \
        --color="fg:#cdd6f4,bg:#1e1e2e,hl:#fab387,prompt:#fab387,pointer:#f5c2e7" \
        --header="Current: ${PROVIDER}")
    [[ -n "$p" ]] && PROVIDER="$p" && printf "${GRN}[✓]${RST} Provider set to: ${BOLD}${PROVIDER}${RST}\n"
}

# ── Update self ───────────────────────────────────────────────
self_update() {
    local install_path
    install_path=$(command -v seri-cli 2>/dev/null || echo "/usr/local/bin/seri-cli")
    printf "${BLU}[~]${RST} Updating seri-cli from GitHub…\n"
    if curl -fsSL "https://raw.githubusercontent.com/yourusername/seri-cli/main/seri-cli" \
        -o "$install_path" 2>/dev/null; then
        chmod +x "$install_path"
        printf "${GRN}[✓]${RST} Updated to latest version.\n"
    else
        printf "${RED}[!] Update failed. Check your connection or the repo URL.${RST}\n"
    fi
}

# ── Help ──────────────────────────────────────────────────────
usage() {
    cat << EOF
${BOLD}seri-cli${RST} v${VERSION} — Stream series, movies & films on Linux

${BOLD}USAGE${RST}
  seri-cli [OPTIONS] [QUERY]

${BOLD}OPTIONS${RST}
  -q, --quality          Select stream quality interactively
  -p, --provider         Switch streaming provider
  -H, --history          Show watch history
  -u, --update           Update seri-cli to latest version
  -h, --help             Show this help
  -v, --version          Show version

${BOLD}EXAMPLES${RST}
  seri-cli "Breaking Bad"
  seri-cli "The Dark Knight"
  seri-cli -q "Chernobyl"          # pick quality first
  seri-cli -p                      # switch provider

${BOLD}CONFIG${RST}
  ${CONFIG_FILE}

${BOLD}HISTORY${RST}
  ${HISTORY_FILE}

${BOLD}PROVIDERS${RST}
  vidsrc      • vidsrc.to  (default)
  multiembed  • multiembed.mov
  vidsrcpro   • vidsrc.pro

${BOLD}DEPENDENCIES${RST}
  Required : curl mpv fzf jq
  Optional : yt-dlp (better quality control)

${DIM}  Streams go from 1980 → 2026 via TMDB metadata.${RST}
EOF
}

# ── Entry point ───────────────────────────────────────────────
main() {
    dep_check
    init_dirs

    [[ $# -eq 0 ]] && { banner; usage; exit 0; }

    local query=""
    local do_quality=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)     usage; exit 0 ;;
            -v|--version)  echo "seri-cli $VERSION"; exit 0 ;;
            -H|--history)  history_show; exit 0 ;;
            -p|--provider) switch_provider; shift ;;
            -u|--update)   self_update; exit 0 ;;
            -q|--quality)  do_quality=true; shift ;;
            -*)            printf "${RED}[!] Unknown flag: $1${RST}\n"; usage; exit 1 ;;
            *)             query="$*"; break ;;
        esac
    done

    banner

    # Interactive search prompt if no query given after flags
    if [[ -z "$query" ]]; then
        printf "${CYN}Search ❯${RST} "
        read -r query
        [[ -z "$query" ]] && exit 0
    fi

    search_and_play "$query"
}

main "$@"
